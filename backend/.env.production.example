APP_NAME=FacturaPro
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://billing.example.com

APP_TIMEZONE=America/Santo_Domingo
APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=30

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=facturapro
DB_USERNAME=facturapro_user
DB_PASSWORD=change_this_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=billing.example.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=facturas@example.com
MAIL_PASSWORD=change_this_password
MAIL_FROM_ADDRESS="facturas@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# On Linux VPS use the Chromium/Chrome binary path instead, e.g.:
# CHROME_PATH=/usr/bin/chromium

# --- Invoice authenticity (anti-forgery) -----------------------------------
# Secret key for the HMAC signature/QR that proves an invoice is system-issued.
# REQUIRED in production. Generate once and keep it OUT of the database:
#   php -r "echo base64_encode(random_bytes(32)).PHP_EOL;"
# WARNING: changing this value invalidates every existing invoice signature.
# Set it BEFORE issuing invoices or running `php artisan invoices:sign-existing`.
INVOICE_SIGNING_KEY=
# Public URL embedded in the invoice QR code. Must be a domain the verifier's
# device can reach. Defaults to APP_URL + /invoices/verify when left empty.
INVOICE_VERIFICATION_URL=https://billing.example.com/invoices/verify

VITE_APP_NAME="${APP_NAME}"
