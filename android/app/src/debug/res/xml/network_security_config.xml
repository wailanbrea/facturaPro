<?xml version="1.0" encoding="utf-8"?>
<!--
    DEBUG-ONLY override. Permits cleartext HTTP to any host so the app can talk
    to a development backend over the LAN (e.g. http://192.168.x.x:8000/api/) or
    the emulator loopback. The release build uses src/main's strict config
    (HTTPS only), so production security is unaffected.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
